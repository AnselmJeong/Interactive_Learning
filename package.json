{
  "name": "learnie",
  "version": "0.6.5",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "LEARNIE_PROJECT_ROOT=$PWD electrobun dev",
    "dev:watch": "LEARNIE_PROJECT_ROOT=$PWD electrobun dev --watch",
    "start": "LEARNIE_PROJECT_ROOT=$PWD electrobun run",
    "prepare:python-runtime": "bun run scripts/prepare-python-runtime.ts",
    "build:dev": "bun install && bun run prepare:python-runtime && electrobun build",
    "build:stable": "bun run prepare:python-runtime && electrobun build --env=stable",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:python": "cd python && uv run --extra test pytest",
    "smoke:python": "LEARNIE_PROJECT_ROOT=$PWD bun run scripts/smoke-python.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "electrobun": "^1.18.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.181.0",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
